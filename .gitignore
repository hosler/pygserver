# QA fixture world (pyReborn's conftest server fixture copies these):
# qa_* are ours; onlinestartlocal.nw is byte-identical to the level the
# open-source GServer-v2 repo ships in bin/servers/default/world/.
!levels/onlinestartlocal.nw
!levels/qa_testlevel.nw
!levels/qa_tier3.nw
levels/*.graal
npcs/*.txt

# GS1 test corpus (Reborn Classic 2004, 5732 .nw files) - kept local, not committed
tests/gs1_corpus/

# runtime player accounts (created at login)
accounts/*.json
